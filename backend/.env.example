# Server
PORT=3001
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=campusloop_db
DB_SSL=false

# Authentication
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRE=7d
ADMIN_JWT_SECRET=replace_with_a_strong_admin_secret
ADMIN_JWT_EXPIRE=1d
ADMIN_EMAIL=admin@campusloop.local
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS=5
STATUS_OTP_EXPIRE_MINUTES=10
STATUS_OTP_MAX_ATTEMPTS=5
STATUS_OTP_RESEND_COOLDOWN_SECONDS=60
STATUS_OTP_MAX_RESENDS=10

# Rate limiting (optional, defaults are applied if omitted)
AUTH_LOGIN_RATE_WINDOW_MINUTES=15
AUTH_LOGIN_RATE_MAX=10
OTP_VERIFY_RATE_WINDOW_MINUTES=10
OTP_VERIFY_RATE_MAX=10
OTP_RESEND_RATE_WINDOW_MINUTES=10
OTP_RESEND_RATE_MAX=5
ADMIN_LOGIN_RATE_WINDOW_MINUTES=15
ADMIN_LOGIN_RATE_MAX=8
STATUS_OTP_REQUEST_RATE_WINDOW_MINUTES=10
STATUS_OTP_REQUEST_RATE_MAX=5
STATUS_OTP_CONFIRM_RATE_WINDOW_MINUTES=10
STATUS_OTP_CONFIRM_RATE_MAX=10

# Initial admin seed account (used by backend/scripts/seedAdmin.js)
SEED_ADMIN_NAME=CampusLoop Admin
SEED_ADMIN_EMAIL=admin@campusloop.local
SEED_ADMIN_PASSWORD=change_me_to_a_strong_password

# Email (SMTP for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM="CampusLoop <noreply@campusloop.local>"

# Cloudinary (required for image upload features)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
